# Jarvis Backend Environment Variables
# Copy this to .env and fill in your API key

# OpenRouter API Key (get yours at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (default: google/gemini-2.5-pro-preview)
OPENROUTER_MODEL=google/gemini-2.5-pro-preview

# Max conversation history turns to keep (per session)
MAX_HISTORY_TURNS=10
